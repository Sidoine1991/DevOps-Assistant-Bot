# Configuration de l'application
NODE_ENV=development
PORT=3000

# Origines CORS (UI sur un autre domaine). Liste séparée par des virgules.
FRONTEND_ORIGINS=

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:your-db-password@your-db-host:5432/postgres?sslmode=require

# Configuration Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_PROJECT_ID=your-project-ref

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Clés API externes
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
OPENAI_API_KEY=sk-your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Configuration monitoring
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# Configuration AWS (pour déploiement)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-3
AWS_ECS_CLUSTER=devops-assistant-bot

# Auth email (OTP)
ADMIN_EMAIL=syebadokpo@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
AUTH_CODE_TTL_MINUTES=10
# Après déploiement : exécuter la migration SQL database/migrations/20260401_auth_codes_purpose.sql
# (colonne purpose sur auth_verification_codes — requis pour mot de passe oublié)

# RAG / ChromaDB
# --- Render (ou autre cloud) : ne pas utiliser 127.0.0.1 — l’app tourne sur un serveur distant. ---
# 1) Déployer le service Docker Chroma (voir deploy/chroma/Dockerfile + render.yaml service "chromadb").
# 2) Dans l’app web : CHROMA_URL = URL HTTPS publique du service Chroma (ex. https://chromadb-xxx.onrender.com).
#    Si la variable est vide, l’app tente CHROMA_HOST:CHROMA_PORT (souvent 127.0.0.1 → échec sur Render).
# 3) Remplir la collection depuis votre PC : CHROMA_URL=https://chromadb-xxx.onrender.com npm run rag:ingest
# 4) Vérifier : GET /api/bot/status → rag.enabled true, rag.chromaUrlConfigured true
CHROMA_URL=
CHROMA_FALLBACK_URL=
# Connexion locale seulement si CHROMA_URL est vide (développement)
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000
CHROMA_SSL=false
# Nom de collection (identique côté app : RAG_COLLECTION dans render.yaml)
RAG_COLLECTION=devops_courses
# Dossier contenant les PDF à ingérer (chemin absolu ou relatif au répertoire du projet)
RAG_DATA_DIR=./data_course
RAG_MAX_CHUNKS_PER_DOC=1200
RAG_INGEST_BATCH_SIZE=4
RAG_RETRIEVAL_TOP_K=16
# Ingestion locale vers Chroma (y compris Chroma en ligne si CHROMA_URL pointe sur Render) :
#   npm run rag:ingest
#   node src/rag/ingest-pdfs.js
