{
  "name": "devops-assistant-bot",
  "version": "1.0.0",
  "description": "DevOps Assistant Bot - Chatbot intelligent pour tâches DevOps",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "build": "echo 'Build completed'",
    "docker:build": "docker build -t devops-assistant-bot .",
    "docker:run": "docker run -p 3000:3000 devops-assistant-bot",
    "chroma:up": "docker-compose up -d chromadb",
    "chroma:down": "docker-compose stop chromadb",
    "chroma:logs": "docker-compose logs -f chromadb",
    "rag:ingest": "node src/rag/ingest-pdfs.js",
    "cap:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npx cap sync android && cd android && gradlew.bat :app:assembleDebug"
  },
  "keywords": [
    "devops",
    "bot",
    "ai",
    "monitoring",
    "deployment"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@chroma-core/default-embed": "^0.1.9",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.101.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.6.0",
    "chromadb": "^3.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^8.0.4",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
